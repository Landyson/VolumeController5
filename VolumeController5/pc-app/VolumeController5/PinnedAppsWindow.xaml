<Window x:Class="VolumeController5.PinnedAppsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Správa připnutých aplikací"
        Height="560" Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#0B1220"
        Foreground="#EAF2FF">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Background" Value="#162A44"/>
            <Setter Property="BorderBrush" Value="#2C4670"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Background" Value="#091426"/>
            <Setter Property="BorderBrush" Value="#35527D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="Background" Value="#091426"/>
            <Setter Property="BorderBrush" Value="#35527D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F1A2E" BorderBrush="#264369" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" Height="32" VerticalAlignment="Center"
                         ToolTip="Vyhledat v běžících aplikacích (např. spot, chrome, discord)" />

                <TextBox x:Name="ManualExeBox" Grid.Column="1" Width="200" Height="32" Margin="12,0,8,0"
                         VerticalAlignment="Center" ToolTip="Přidat ručně (např. spotify.exe nebo cesta k exe)" />

                <Button x:Name="AddManualBtn" Grid.Column="2" Content="Přidat" Width="90" Height="32"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Běžící aplikace (EXE)" Grid.Column="0" Margin="0,0,12,0">
                <Grid Margin="6">
                    <ListBox x:Name="RunningList" />
                </Grid>
            </GroupBox>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Button x:Name="AddBtn" Content="&gt;&gt;" Width="80" Height="36" Margin="0,0,0,10"/>
                <Button x:Name="RemoveBtn" Content="&lt;&lt;" Width="80" Height="36"/>
            </StackPanel>

            <GroupBox Header="Připnuté (budou vždy v dropdownu)" Grid.Column="2" Margin="12,0,0,0">
                <Grid Margin="6">
                    <ListBox x:Name="PinnedList" />
                </Grid>
            </GroupBox>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0" LastChildFill="False">
            <TextBlock x:Name="StatusText" DockPanel.Dock="Left" Opacity="0.8" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="ClearAllBtn" Content="Odebrat vše" Width="120" Height="34" Margin="0,0,8,0"/>
                <Button x:Name="CancelBtn" Content="Zrušit" Width="110" Height="34" Margin="0,0,8,0"/>
                <Button x:Name="OkBtn" Content="Uložit" Width="110" Height="34"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
